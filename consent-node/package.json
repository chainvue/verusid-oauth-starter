{
  "name": "verus-oauth-consent-node",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only --watch src,views src/server.ts",
    "start": "node lib/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ory/hydra-client-fetch": "^2.4.0-alpha.1",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "pug": "^3.0.3",
    "qrcode": "^1.5.4",
    "url-join": "^4.0.1",
    "verus-typescript-primitives": "github:VerusCoin/verus-typescript-primitives#72d477b836538d6c734162b2c069538122263f3b",
    "verusid-ts-client": "github:VerusCoin/verusid-ts-client#2eec86c7f06d13c8b04ddc1473fce32c450d2a31"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/url-join": "^4.0.3",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@types/express-serve-static-core": "4.19.8",
      "axios": "^1.17.0",
      "base-x": "3.0.11",
      "cookie": "^1.1.1"
    },
    "patchedDependencies": {
      "bitcoin-ops@1.4.1": "patches/bitcoin-ops@1.4.1.patch"
    }
  }
}
