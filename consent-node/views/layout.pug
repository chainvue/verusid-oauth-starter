doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Verus OAuth Consent
    style.
      :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
      body { margin: 0; background: #f6f7f9; color: #1d2430; }
      main { max-width: 560px; margin: 8vh auto; padding: 0 20px; }
      .panel { background: #fff; border: 1px solid #d9dee7; border-radius: 8px; padding: 28px; box-shadow: 0 12px 30px rgb(29 36 48 / 8%); }
      h1 { margin: 0 0 18px; font-size: 24px; line-height: 1.2; }
      p { line-height: 1.5; }
      label { display: block; margin: 14px 0 6px; font-weight: 600; }
      .check { display: flex; gap: 10px; align-items: center; margin: 16px 0; font-weight: 500; }
      .actions { display: flex; gap: 10px; margin-top: 22px; }
      button, .button { display: inline-flex; align-items: center; justify-content: center; border: 1px solid #1f6feb; border-radius: 6px; padding: 10px 14px; background: #1f6feb; color: white; font: inherit; font-weight: 700; cursor: pointer; text-decoration: none; }
      button.secondary, .button.secondary { border-color: #c3cad5; background: white; color: #303846; }
      .error { color: #a32424; background: #fff0f0; border: 1px solid #f0caca; padding: 10px 12px; border-radius: 6px; }
      .status { color: #303846; background: #f1f5f9; border: 1px solid #d9dee7; padding: 10px 12px; border-radius: 6px; }
      .qr { display: block; width: min(100%, 320px); height: auto; margin: 18px auto; border: 1px solid #d9dee7; border-radius: 8px; }
      ul { padding-left: 20px; }
  body
    main
      .panel
        block content
